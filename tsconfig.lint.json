{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "types": [
      "bindings",
      "multicast-dns",
      "node",
      "ws"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**",
    "**/test/**",
    "console/**",
    "bench-visualization/**"
  ]
}

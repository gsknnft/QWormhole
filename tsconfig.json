{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "lib":  ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@sigilnet/coherence": ["../coherence/dist/index.d.ts"],
      "@sigilnet/coherence/*": ["../coherence/dist/*"]
    },
    "rootDir": "src",
    "composite": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "typeRoots": [
      "src/types/types",
      "../../src/types"
    ]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "**/dist", "**/test"]
}

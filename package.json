{
  "name": "@gsknnft/qwormhole",
  "version": "0.3.0",
  "description": "A high-performance, extensible TypeScript socket library with native bindings for Node.js",
  "private": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./index.js": "./dist/index.js",
    "./index.cjs": "./dist/index.js",
    "./index.mjs": "./dist/index.js",
    "./types": "./dist/types/index.d.ts",
    "./browser": {
      "types": "./dist/types/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.js"
    },
    "./legacy/coherence": {
      "types": "./dist/types/legacy/coherence.d.ts",
      "import": "./dist/legacy/coherence.js",
      "require": "./dist/legacy/coherence.js"
    },
    "./native": {
      "import": "./dist/native/qwormhole_lws.node"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "prebuilds",
    "binding.gyp",
    "c"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gsknnft/QWormhole.git"
  },
  "author": "Gordon Skinner",
  "license": "BSD-3-Clause",
  "keywords": [
    "tcp",
    "transport",
    "typescript",
    "native-addon",
    "libwebsockets",
    "socket",
    "networking",
    "framing",
    "backpressure"
  ],
  "scripts": {
    "build:tsup": "tsup",
    "build:vite": "vite build",
    "mathplotlib": "python scripts/plot_bench.py /data/*.csv",
    "rebuild:binds": "node -e \"const fs=require('fs');const path=require('path');fs.mkdirSync(path.join(__dirname,'dist','native'),{recursive:true});for (const name of ['qwormhole.node','qwormhole_lws.node']){const src=path.join(__dirname,'build','Release',name);const dst=path.join(__dirname,'dist','native',name);if(fs.existsSync(src)){fs.copyFileSync(src,dst);console.log('[qwormhole] copied',src,'->',dst);}}\"",
    "rebuild": "node ./scripts/install-native.js && pnpm run rebuild:binds && pnpm build",
    "rebuild:native-only": "node -e \"process.env.QWORMHOLE_NATIVE_FORCE_REBUILD='1'; import('./scripts/install-native.js')\" && pnpm run rebuild:binds",
    "rebuild:force-native": "node -e \"process.env.QWORMHOLE_NATIVE_FORCE_REBUILD='1'; import('./scripts/install-native.js')\" && pnpm run rebuild:binds && pnpm build",
    "build:tsc": "tsc -p tsconfig.json",
    "build:rollup": "rollup -c",
    "build": "vite build && pnpm run build:tsc && pnpm run build:decl && pnpm run rebuild:binds",
    "build:decl": "tsc --emitDeclarationOnly --declaration --outDir dist/types --project tsconfig.json",
    "install": "node ./scripts/install-native.js",
    "prepack": "node -e \"const fs=require('fs');const p='dist/tsconfig.tsbuildinfo';if(fs.existsSync(p))fs.rmSync(p,{force:true});\"",
    "prepublishOnly": "pnpm run build && pnpm run test",
    "dev": "tsup --watch",
    "test": "vitest run",
    "dev:console": "cd ./app && pnpm dev:console",
    "app:idev": "cd ./app && pnpm install && pnpm dev:console",
    "test:native": "vitest run test/native.smoke.test.ts",
    "bench": "tsx scripts/bench.ts",
    "bench2": "tsx scripts/benchv1.ts",
    "bench:writev": "tsx scripts/bench-writev.ts",
    "test:kcp": "tsx scripts/dev/kcp-mux-test.ts",
    "test:sharded-smoke": "tsx scripts/dev/worker-sharded-smoke.ts",
    "test:routed-sharded-smoke": "tsx scripts/dev/routed-sharded-smoke.ts",
    "test:secure-native-lws-smoke": "tsx scripts/dev/secure-native-lws-smoke.ts",
    "test:ws": "tsx scripts/dev/ws-mux-test.ts",
    "bench:sweep": "node scripts/run-bench-sweep.js",
    "bench:sweep:ts": "node scripts/run-bench-sweep-ts.js",
    "bench:qw": "pnpm run bench -- --mode=all --diagnostics",
    "bench:core": "pnpm run bench -- --mode=core --diagnostics",
    "bench:core:report": "node scripts/run-bench-core-report.js",
    "bench:core:structure": "node scripts/run-bench-core-report.js --structure",
    "bench:core:delta": "node scripts/generate-bench-delta-report.js --raw data/core_diagnostics.jsonl --structure data/core_diagnostics.structure.jsonl --out data/core_diagnostics.delta.md --title \"QWormhole Core Bench Delta Report\"",
    "bench:core:sharded:report": "node scripts/run-bench-core-sharded-report.js",
    "bench:core:routed-sharded:report": "node scripts/run-bench-core-routed-sharded-report.js",
    "bench:core:multi:report": "node scripts/run-bench-core-report.js --multi",
    "bench:core:multi:structure": "node scripts/run-bench-core-report.js --multi --structure",
    "bench:core:highconcurrency:report": "node scripts/run-bench-core-report.js --high-concurrency",
    "bench:core:highconcurrency:structure": "node scripts/run-bench-core-report.js --high-concurrency --structure",
    "bench:compare:report": "node scripts/run-bench-compare-report.js",
    "bench:compare:structure": "node scripts/run-bench-compare-report.js --structure",
    "bench:compare:delta": "node scripts/generate-bench-delta-report.js --raw data/compare_diagnostics.jsonl --structure data/compare_diagnostics.structure.jsonl --out data/compare_diagnostics.delta.md --title \"QWormhole Compare Bench Delta Report\"",
    "bench:compare:multi:report": "node scripts/run-bench-compare-report.js --multi",
    "bench:compare:multi:structure": "node scripts/run-bench-compare-report.js --multi --structure",
    "bench:compare:highconcurrency:report": "node scripts/run-bench-compare-report.js --high-concurrency",
    "bench:compare:highconcurrency:structure": "node scripts/run-bench-compare-report.js --high-concurrency --structure",
    "native:stage-prebuilds": "node ./scripts/stage-prebuilds.cjs",
    "lint": "tsc -p tsconfig.lint.json --noEmit",
    "lint:eslint": "eslint .",
    "lint:full": "pnpm run lint:eslint && pnpm run lint",
    "format": "prettier . --write"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "include": [
      "src/**/*"
    ],
    "loader": {
      ".wasm": "file"
    },
    "format": [
      "cjs",
      "esm"
    ],
    "tsconfig": "./tsconfig.json",
    "dts": false,
    "splitting": false,
    "sourcemap": true,
    "shims": true,
    "clean": true,
    "target": "es2022",
    "external": [
      "bindings"
    ],
    "noExternal": []
  },
  "prettier": {
    "tabWidth": 2,
    "semi": true,
    "arrowParens": "avoid"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.3",
    "@eslint/js": "^9.39.1",
    "@types/bindings": "^1.5.5",
    "@types/multicast-dns": "7.2.4",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.15",
    "eslint": "^9.39.1",
    "fast-check": "^4.3.0",
    "node-addon-api": "8.5.0",
    "node-gyp": "12.2.0",
    "node-gyp-build": "4.8.4",
    "prebuildify": "6.0.1",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.16.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.58.0",
    "vite": "7.2.4",
    "vitest": "^4.0.9",
    "zod": "^4.1.13"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.53.3"
  },
  "dependencies": {
    "@gsknnft/coherence": "0.1.1",
    "@tensorflow/tfjs": "4.22.0",
    "bindings": "^1.5.0",
    "cbor": "^10.0.11",
    "multicast-dns": "7.2.5",
    "multicast-dns-service-types": "1.1.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.3"
  }
}
